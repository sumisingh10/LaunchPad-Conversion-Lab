# Backend
# Set a long random value in real environments.
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/launchpad
LOCAL_DATABASE_URL=sqlite+pysqlite:///./launchpad.db
USE_SQLITE=false
FRONTEND_ORIGIN=http://localhost:3000
CODEX_API_KEY=
CODEX_API_KEY_FILE=
CODEX_API_KEY_ENCRYPTED=
CODEX_API_KEY_DECRYPTION_KEY=
CODEX_API_KEY_DECRYPTION_KEY_FILE=
CODEX_PROVIDER=cli
CODEX_CLI_PATH=codex
CODEX_CLI_TIMEOUT_SECONDS=90
CODEX_MODEL=gpt-4.1-mini
CODEX_USE_FALLBACK=true
CODEX_REQUESTS_PER_MINUTE=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
